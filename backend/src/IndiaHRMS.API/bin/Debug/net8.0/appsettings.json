{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=IndiaHRMS;User Id=sa;Password=YourPassword@123;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "SecretKey": "REPLACE_WITH_64_CHAR_SECRET_KEY_FOR_PRODUCTION_USE",
    "Issuer": "IndiaHRMS",
    "Audience": "IndiaHRMS-Client",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "EncryptionSettings": {
    "Key": "REPLACE_WITH_32_CHAR_ENCRYPTION_K",
    "IV": "REPLACE_WITH_16IV"
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": "587",
    "FromName": "IndiaHRMS",
    "FromEmail": "noreply@yourcompany.com",
    "Username": "",
    "Password": ""
  },
  "Redis": {
    "ConnectionString": ""
  },
  "FileStorage": {
    "BasePath": "uploads",
    "MaxFileSizeMB": 10,
    "AllowedExtensions": [ ".pdf", ".jpg", ".jpeg", ".png", ".doc", ".docx", ".xlsx" ]
  },
  "Security": {
    "MaxFailedLoginAttempts": 5
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": false,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 200
      },
      {
        "Endpoint": "POST:/api/*/auth/login",
        "Period": "1m",
        "Limit": 10
      }
    ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
